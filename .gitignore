# ============================================================================
# Raw survey microdata — NEVER committed.
# These are obtained from the World Bank LSMS-ISA program; see DATA_SOURCES.md.
# ============================================================================
*.dta
*.zip
*.tar.gz
*.sav
*.7z

# Generated outputs (rebuilt by running the code) — keep the dirs, ignore contents
Output/Temp/*
Output/Final/*
!Output/Temp/.gitkeep
!Output/Final/.gitkeep
*.gph

# Stata / R / OS scratch
*.log
*.smcl
~$*
*.stswp
.~lock.*
.Rhistory
.RData
.Rproj.user/
.DS_Store
Thumbs.db


# consolidated report build artifacts (regenerable)
Report/.pdf_src.md

# Python bytecode cache
__pycache__/
*.pyc

# Local session handoff notes (not for the public repo)
SESSION_NOTES.md

# EXCEPTION: ship the compressed pooled parcel-level dataset so the tables can be
# reproduced without the raw microdata (this negation must stay after *.zip and
# Output/Final/* above so it wins). The uncompressed .dta stays ignored.
!Output/Final/rental_tenure_ALL.dta.zip
