# ============================================================================
# Raw survey microdata — NEVER committed.
# These are obtained from the World Bank LSMS-ISA program; see DATA_SOURCES.md.
# ============================================================================
*.dta
*.zip
*.tar.gz
*.sav
*.7z

# Generated outputs (rebuilt by running the code) — keep the dirs, ignore contents
Output/Temp/*
Output/Final/*
!Output/Temp/.gitkeep
!Output/Final/.gitkeep
*.gph

# Stata / R / OS scratch
*.log
*.smcl
~$*
*.stswp
.~lock.*
.Rhistory
.RData
.Rproj.user/
.DS_Store
Thumbs.db


# consolidated report build artifacts (regenerable)
Report/.pdf_src.md

# Python bytecode cache
__pycache__/
*.pyc
